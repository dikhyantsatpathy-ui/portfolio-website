rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && 
             request.auth.token.email == 'dikhyantsatpathy@gmail.com';
    }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidProfile(data) {
      return data.keys().hasAll(['name', 'ownerId', 'updatedAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.ownerId is string && data.ownerId.size() <= 128 &&
             data.ownerId == request.auth.uid;
    }
    
    function isValidSection(data) {
      return data.keys().hasOnly(['title', 'type', 'items', 'order', 'visible', 'updatedAt', 'ownerId']) &&
             data.title is string && data.title.size() <= 100 &&
             data.type is string && data.type.size() <= 50 &&
             data.items is list && data.items.size() <= 100 &&
             data.order is number &&
             data.visible is bool &&
             data.ownerId is string && data.ownerId.size() <= 128 &&
             data.ownerId == request.auth.uid;
    }

    match /profiles/{profileId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(profileId) && isValidProfile(incoming()) && incoming().updatedAt == request.time;
      allow update: if isAdmin() && isValidId(profileId) && isValidProfile(incoming()) && incoming().updatedAt == request.time && incoming().ownerId == existing().ownerId;
      allow delete: if isAdmin() && isValidId(profileId);
    }

    match /sections/{sectionId} {
      allow list: if resource.data.visible == true || isAdmin();
      allow get: if resource.data.visible == true || isAdmin();
      allow create: if isAdmin() && isValidId(sectionId) && isValidSection(incoming()) && incoming().updatedAt == request.time;
      allow update: if isAdmin() && isValidId(sectionId) && isValidSection(incoming()) && incoming().updatedAt == request.time && incoming().ownerId == existing().ownerId;
      allow delete: if isAdmin();
    }

    match /blocked_ips/{ip} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /visitors/{ip} {
      allow read: if isAdmin();
      allow create, update: if true;
    }

    match /messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
